#!/usr/bin/env bash

set -euo pipefail

ORION_URL="${ORION_URL:-http://localhost:1026}"

echo "⏳ Loading NGSIv2 context data into Orion (${ORION_URL})..."

post_entity() {
  local payload="$1"
  local code
  code="$(curl -s -o /dev/null -w "%{http_code}" \
    -X POST "${ORION_URL}/v2/entities" \
    -H 'Content-Type: application/json' \
    -d "$payload")"

  if [ "$code" != "201" ] && [ "$code" != "422" ]; then
    echo "❌ Error creating entity (HTTP $code)"
    echo "$payload"
    exit 1
  fi
}

post_registration() {
  local payload="$1"
  local code
  code="$(curl -s -o /dev/null -w "%{http_code}" \
    -X POST "${ORION_URL}/v2/registrations" \
    -H 'Content-Type: application/json' \
    -d "$payload")"

  if [ "$code" != "201" ] && [ "$code" != "422" ]; then
    echo "⚠️ Registration skipped (HTTP $code)"
  fi
}

