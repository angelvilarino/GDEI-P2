# -----------------------------------------------------------------------------
# Inventory items (mínimo 4 productos por estantería en todas las tiendas)
# -----------------------------------------------------------------------------
inventory_id=1

for shelf_num in $(seq 1 16); do
  shelf_id=$(printf "urn:ngsi-ld:Shelf:%03d" "$shelf_num")
  store_num=$(( (shelf_num - 1) / 4 + 1 ))
  store_id=$(printf "urn:ngsi-ld:Store:%03d" "$store_num")

  # 4 productos distintos por shelf (rotación sobre catálogo de 10 productos)
  for offset in 0 1 2 3; do
    product_num=$(( ((shelf_num - 1 + offset) % 10) + 1 ))
    product_id=$(printf "urn:ngsi-ld:Product:%03d" "$product_num")
    item_id=$(printf "urn:ngsi-ld:InventoryItem:%03d" "$inventory_id")

    stock_count=$((70 + (shelf_num * 4) + (offset * 6)))
    shelf_count=$((12 + offset * 3))

    post_entity "{\"id\":\"${item_id}\",\"type\":\"InventoryItem\",\"refStore\":{\"type\":\"Relationship\",\"value\":\"${store_id}\"},\"refShelf\":{\"type\":\"Relationship\",\"value\":\"${shelf_id}\"},\"refProduct\":{\"type\":\"Relationship\",\"value\":\"${product_id}\"},\"stockCount\":{\"type\":\"Integer\",\"value\":${stock_count}},\"shelfCount\":{\"type\":\"Integer\",\"value\":${shelf_count}}}"

    inventory_id=$((inventory_id + 1))
  done
done

